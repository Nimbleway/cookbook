# Copy to .env and fill the two secrets. Keep values on clean KEY=value lines with NO inline
# comments (a trailing "# ..." becomes part of the value when the file is sourced).
# Do NOT add ANTHROPIC_API_KEY here — auth is your `ant auth login` profile; a blank or stale
# key in this file would silently override the profile and break auth.
#
# NIMBLE_API_KEY   Nimble API key (used as the bearer for https://mcp.nimbleway.com/mcp)
# SLACK_BOT_TOKEN  Slack bot token (xoxb-...); the agent posts the digest via the Slack Web API.
#                  The bot must be a member of the target channel (set in the profile).
NIMBLE_API_KEY=
SLACK_BOT_TOKEN=

# Filled in automatically by scripts/00-setup.sh and 10-deploy.sh:
ENV_ID=
VAULT_ID=
MEMSTORE_ID=
COMPETITOR_INTEL_SKILL_ID=
AGENT_ID=
DEPL_ID=
