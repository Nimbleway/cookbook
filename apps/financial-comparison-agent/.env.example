# Nimble Web Search Agent platform — https://sdk.nimbleway.com
NIMBLE_API_KEY=your_nimble_api_key

# Claude (Anthropic) — the agent's reasoning model
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase: Project Settings -> API -> Project URL + service_role key
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_service_role_key

# Optional model override (defaults to claude-sonnet-4-6 — fast & cost-effective for the loop)
COMPS_MODEL=claude-sonnet-4-6

# Set to false to serve cached Nimble responses (video-safe, no live API calls)
USE_LIVE=true
