NIMBLE_API_KEY=your_nimble_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
SUPABASE_URL=https://your-project.supabase.co
# service_role bypasses Row Level Security — server-side only, never expose to clients.
# For public deployments use the anon key with RLS policies instead.
SUPABASE_KEY=your_service_role_key
USE_LIVE=true
ENRICH_CAP=10
