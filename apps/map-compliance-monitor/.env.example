# Nimble Web Search Agents
NIMBLE_API_KEY=your_nimble_api_key

# App runtime: dashboard reads cached data unless USE_LIVE=true
USE_LIVE=false

# Discovery orchestration (optional overrides)
MCM_CONCURRENCY=8
MCM_MIN_SELLERS=6

# Google action layer (optional — local fallback used when unset)
# Service-account JSON path with Sheets + Docs + Drive scope
GOOGLE_SA_JSON=./service-account.json
GOOGLE_SHEET_ID=your_target_sheet_id
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_for_notices
