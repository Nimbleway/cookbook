# Nimble — powers the Diligence Analyst agent (Web Search Agents v2)
NIMBLE_API_KEY=your_nimble_api_key

# Anthropic — powers the CrewAI review crew (QA -> Risk Officer -> Editor)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase — memo, claim, follow-up, and learning storage (free tier)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key
# Note: the service_role key bypasses row-level security — server-side use only.

# Email action (optional). Without a key the app shows an email preview
# and saves the PDF locally instead of sending.
RESEND_API_KEY=
EMAIL_FROM=diligence-desk@resend.dev

# false = replay the bundled sample memo through the same code paths (no API calls)
USE_LIVE=true
