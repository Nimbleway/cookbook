# SvelteKit web — copy to web/.env for local dev. Vercel: set in project Settings → Environment Variables.

# Python agent bridge (local: uvicorn on 8787; prod: https://<app>.fly.dev)
AGENT_URL=http://127.0.0.1:8787

# Must match Fly `BRIDGE_SECRET` when deployed. Leave empty for local-only dev (no check on bridge).
BRIDGE_SECRET=

# UI-only mock SSE (no bridge required)
# MOCK=1

# --- Future: Supabase ---
# PUBLIC_SUPABASE_URL=
# PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
