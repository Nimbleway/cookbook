# Startup.Delivery — copy to .env for local agent bridge. NEVER commit .env.
# Web app vars: see web/.env.example (AGENT_URL, BRIDGE_SECRET).

# --- Bridge security (Fly + Vercel must match) ---
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
BRIDGE_SECRET=

# --- Nimble (live web recon, Step 1) --- https://nimbleway.com
# ~5,000 free pages. CACHE every response to disk so code changes don't re-burn quota.
NIMBLE_API_KEY=

# --- name.com (domain availability + price, Step 3) --- THE load-bearing integration.
# PRODUCTION is the intended path: real availability for real domains. Use the
# PROD base, a username WITHOUT the -test suffix, and a PRODUCTION API token.
# The boot control-check flags LOUDLY (warning log + /health + /debug domainSource)
# if the SANDBOX is still configured — the sandbox reports registered domains
# (google.com, etc.) as buyable for ~$13, which is NOT real availability.
NAMECOM_USERNAME=yourname
NAMECOM_API_TOKEN=
NAMECOM_API_BASE=https://api.name.com   # prod. sandbox/test = https://api.dev.name.com (+ -test username)

# --- OpenRouter (LLM gateway — Steps 2 & 4) --- https://openrouter.ai
# One key, many models. Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4     # swap anytime: google/gemini-2.5-pro-preview, openai/gpt-4.1, etc.
OPENROUTER_SITE_URL=https://startup-delivery.vercel.app   # optional; shown on openrouter.ai rankings
OPENROUTER_APP_NAME=Startup.Delivery                    # optional; shown on openrouter.ai rankings

# --- Tower (serverless compute + lakehouse) --- usually handled by `tower login`
# TOWER_API_KEY=
