# ─── AI ───────────────────────────────────────────────
# Claude powers the hero summary & "Ask Nimble" answers.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional kill switch for all Claude calls. Set to "off" to force the
# deterministic (rule-based) fallbacks everywhere. Default: on.
AI_ENRICH=on

# ─── Nimble (Live Mode only — Demo Mode needs none of these) ───
# Get a key at https://app.nimbleway.com . Live Mode activates only when
# NIMBLE_API_KEY is set AND at least one agent var below is configured.
NIMBLE_API_KEY=

# Each *_SERP_AGENT_ENDPOINT may be EITHER a Nimble agent name (recommended)
# OR a full endpoint URL. Defaults shown are the canonical public agents.
NIMBLE_AMAZON_SERP_AGENT_ENDPOINT=amazon_serp
NIMBLE_WALMART_SERP_AGENT_ENDPOINT=walmart_serp
NIMBLE_TARGET_SERP_AGENT_ENDPOINT=target_serp

# Force Demo Mode even when Nimble keys are present (handy for offline demos).
# FORCE_DEMO=1

# ─── Lead capture → HubSpot + Slack ───────────────────
# The in-app "Get in touch for more data" form posts to /api/lead, which
# forwards the contact to HubSpot (Forms Submission API — no API key needed,
# it authenticates by portal + form GUID) and optionally pings a webhook.
# Find both IDs in your HubSpot form's embed code. Region is na1 / eu1 / etc.
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=
HUBSPOT_REGION=eu1

# Optional: a Slack incoming webhook (or Pipedream/Zapier URL) for an instant
# "new lead" ping. Leave UNSET if HubSpot already runs a HubSpot→Slack
# workflow (otherwise you'd get duplicate notifications).
# LEAD_WEBHOOK_URL=

# ─── Event Mode (public, safe to expose) ───────────────
# Setting an event name shows the top banner. Empty = no banner.
NEXT_PUBLIC_EVENT_NAME=""

# Fallback contact for the "Prefer email? Write to us directly" link inside the
# lead form (the primary path is the in-app form → HubSpot).
NEXT_PUBLIC_CONTACT_EMAIL="salinas@nimbleway.com"

# Optional: point the email-fallback link at a booking page instead of a mailto.
# NEXT_PUBLIC_BOOKING_URL="https://…"

# ─── Landing & performance ────────────────────────────
# Default (unset/empty) = land on the hero/home page. Set to a category to
# auto-load a live result on first paint instead — ONLY on a prewarmed machine
# (on cold serverless this shows a ~20s scan on load). e.g. "energy drinks"
NEXT_PUBLIC_LANDING_CATEGORY=""

# Warm the live cache for the prepared categories on the first live request so
# the landing scan is instant instead of a ~20s cold pull. Costs Nimble credits
# up front. Live cache TTL is 10 min.
PREWARM_LIVE=true
